{
  "name": "@beyas/packi",
  "version": "1.1.2",
  "type": "module",
  "description": "Smart CLI package installer for Node.js — reads requirements.txt, installs npm packages with fuzzy-match suggestions, progress tracking, and a community-powered package database.",
  "main": "cli.js",
  "exports": {
    ".": {
      "import": "./cli.js",
      "types": "./types/index.d.ts"
    }
  },
  "bin": {
    "packi": "./cli.js"
  },
  "scripts": {
    "test": "node -e \"console.log('No tests configured')\"",
    "start": "node cli.js",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "npm",
    "installer",
    "package-manager",
    "cli",
    "requirements",
    "fuzzy-search",
    "automation",
    "devtools",
    "easy-install"
  ],
  "author": {
    "name": "Bekono Beyas Ambroise (ThorLex)",
    "email": "b.galaxy.dev@gmail.com",
    "url": "https://github.com/ThorLex"
  },
  "license": "MIT",
  "homepage": "https://github.com/ThorLex/packInstaller#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ThorLex/packInstaller.git"
  },
  "bugs": {
    "url": "https://github.com/ThorLex/packInstaller/issues",
    "email": "b.galaxy.dev@gmail.com"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "files": [
    "cli.js",
    "src/",
    "exists.txt",
    "README.md",
    "LICENSE",
    "types/"
  ],
  "dependencies": {
    "string-similarity": "^4.0.4"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
